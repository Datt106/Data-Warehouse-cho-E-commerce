{
  "datasets": [
    {
      "name": "cb8fc485",
      "displayName": "Sales Trend",
      "queryLines": [
        "SELECT \r\n",
        "    -- Ghép Năm-Tháng để hiển thị trục X\r\n",
        "    concat(d.year, '-', lpad(d.month, 2, '0')) as year_month, \r\n",
        "    SUM(f.sales_amount) as total_revenue,\r\n",
        "    COUNT(DISTINCT f.order_id) as total_orders\r\n",
        "FROM brazilian_ecommerce.gold.fact_sales f\r\n",
        "JOIN brazilian_ecommerce.gold.dim_date d ON f.date_id = d.date_id\r\n",
        "GROUP BY 1\r\n",
        "ORDER BY 1"
      ]
    },
    {
      "name": "c7fdd319",
      "displayName": "Top Products",
      "queryLines": [
        "SELECT \r\n",
        "    p.category_english,\r\n",
        "    SUM(f.sales_amount) as revenue\r\n",
        "FROM brazilian_ecommerce.gold.fact_sales f\r\n",
        "JOIN brazilian_ecommerce.gold.dim_products p ON f.product_sk = p.product_sk\r\n",
        "WHERE p.category_english IS NOT NULL\r\n",
        "GROUP BY 1\r\n",
        "ORDER BY 2 DESC\r\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "2f37976a",
      "displayName": "Geography",
      "queryLines": [
        "SELECT \r\n",
        "    c.customer_state,\r\n",
        "    COUNT(DISTINCT c.customer_natural_key) as customer_count,\r\n",
        "    SUM(f.sales_amount) as revenue\r\n",
        "FROM brazilian_ecommerce.gold.fact_sales f\r\n",
        "JOIN brazilian_ecommerce.gold.dim_customers c ON f.customer_sk = c.customer_sk\r\n",
        "-- WHERE c.is_current = true  <-- Tạm thời comment dòng này lại\r\n",
        "GROUP BY 1\r\n",
        "ORDER BY 3 DESC"
      ]
    },
    {
      "name": "d898e55f",
      "displayName": "Payments",
      "queryLines": [
        "SELECT \r\n",
        "    payment_type,\r\n",
        "    SUM(payment_value) as total_value\r\n",
        "FROM brazilian_ecommerce.gold.fact_payments\r\n",
        "GROUP BY 1\r\n",
        "ORDER BY 2 DESC"
      ]
    }
  ],
